{
    "name": "tyeblog",
    "type": "module",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "check": "astro check",
        "format": "prettier --write \"**/*.{astro,css,json,md,mdx,mjs,ts,yaml,yml}\" \".github/**/*.{yaml,yml}\" --ignore-unknown",
        "format:check": "prettier --check \"**/*.{astro,css,json,md,mdx,mjs,ts,yaml,yml}\" \".github/**/*.{yaml,yml}\" --ignore-unknown",
        "prepare": "husky",
        "test": "node --test",
        "verify:dist": "node tests/verify-dist.mjs"
    },
    "dependencies": {
        "@astrojs/mdx": "^4.3.0",
        "@astrojs/rss": "^4.0.12",
        "@astrojs/sitemap": "^3.4.1",
        "astro": "^5.9.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.4",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.6",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "typescript": "^5.8.3"
    },
    "lint-staged": {
        "*.{astro,css,json,md,mdx,mjs,ts,yaml,yml}": "prettier --write"
    }
}
