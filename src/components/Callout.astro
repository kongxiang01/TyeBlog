---
interface Props { title?: string; }
const { title = "NOTE" } = Astro.props;
---
<aside class="callout">
  <strong>{title}</strong>
  <div><slot /></div>
</aside>
<style>
  .callout { margin: 28px 0; padding: 16px 18px; border-left: 3px solid var(--accent); background: var(--surface-strong); }
  strong { display: block; margin-bottom: 8px; color: var(--accent); font: 800 .69rem/1.3 "SFMono-Regular", Consolas, monospace; letter-spacing: .1em; }
  .callout :global(p) { margin: 0; }
</style>

