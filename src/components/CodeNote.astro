---
interface Props {
    label?: string;
}
const { label = "CODE NOTE" } = Astro.props;
---

<aside class="code-note">
    <span>{label}</span>
    <div><slot /></div>
</aside>
<style>
    .code-note {
        margin: 24px 0;
        padding: 15px 17px;
        border: 1px solid var(--line);
        background: #edf3f2;
    }
    span {
        color: var(--accent);
        font:
            800 0.66rem/1.3 "SFMono-Regular",
            Consolas,
            monospace;
        letter-spacing: 0.1em;
    }
    .code-note :global(p) {
        margin-bottom: 0;
    }
</style>
